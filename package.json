{
	"name": "chance-dot-dev",
	"version": "0.1.0",
	"private": true,
	"author": "Chance Strickland <hi@chancedigital.io> (https://chancedigital.io/)",
	"repository": {
		"type": "git",
		"url": "https://github.com/chaance/chance-dot-dev"
	},
	"bugs": {
		"url": "https://github.com/chaance/chance-dot-dev"
	},
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"postbuild": "next-on-netlify",
		"lint": "eslint .",
		"clean:next": "rm -rf .next",
		"clean:node": "rm -rf node_modules",
		"clean": "yarn clean:next && yarn clean:node"
	},
	"dependencies": {
		"@chancestrickland/hooks": "^0.1.1",
		"@mdx-js/react": "^1.6.22",
		"@ngsctt/remark-smartypants": "^0.2.0",
		"@reach/alert": "^0.13.0",
		"@reach/auto-id": "^0.13.0",
		"@reach/skip-nav": "^0.13.0",
		"@reach/tooltip": "^0.13.0",
		"@reach/visually-hidden": "^0.13.0",
		"clsx": "^1.1.1",
		"fontfaceobserver": "^2.1.0",
		"fs-extra": "^9.1.0",
		"gray-matter": "^4.0.2",
		"lodash": "^4.17.20",
		"luxon": "^1.25.0",
		"next": "10.0.6",
		"next-mdx-remote": "^2.1.3",
		"next-on-netlify": "^2.8.7",
		"next-seo": "^4.19.0",
		"postcss-flexbugs-fixes": "^5.0.2",
		"postcss-preset-env": "^6.7.0",
		"react": "^17.0.1",
		"react-dom": "^17.0.1",
		"react-polymorphic-types": "^1.0.3",
		"rehype": "^11.0.0",
		"remark-capitalize": "^1.1.0",
		"remark-images": "^2.0.0",
		"remark-slug": "^6.0.0",
		"sass": "^1.32.5",
		"use-dark-mode": "^2.3.1",
		"yup": "^0.32.8"
	},
	"devDependencies": {
		"@chancedigital/browserslist-config": "^1.0.4",
		"@chancedigital/eslint-config": "^8.0.0",
		"@types/fs-extra": "^9.0.6",
		"@types/lodash": "^4.14.168",
		"@types/luxon": "^1.25.1",
		"@types/mdx-js__react": "^1.5.3",
		"@types/node": "^14.14.22",
		"@types/react": "^17.0.0",
		"@types/react-dom": "^17.0.0",
		"@typescript-eslint/eslint-plugin": "^4.14.1",
		"@typescript-eslint/parser": "^4.14.1",
		"babel-eslint": "^10.1.0",
		"eslint": "^7.18.0",
		"eslint-plugin-import": "^2.22.1",
		"eslint-plugin-jest": "^24.1.3",
		"eslint-plugin-jsx-a11y": "^6.4.1",
		"eslint-plugin-react": "^7.22.0",
		"eslint-plugin-react-hooks": "^4.2.0",
		"eslint-plugin-testing-library": "^3.10.1",
		"glob": "^7.1.6",
		"is-glob": "^4.0.1",
		"prettier": "^2.2.1",
		"typescript": "^4.1.3"
	},
	"prettier": {
		"semi": true,
		"trailingComma": "es5",
		"useTabs": true
	},
	"browserslist": [
		"extends @chancedigital/browserslist-config"
	],
	"eslintConfig": {
		"extends": [
			"@chancedigital",
			"@chancedigital/eslint-config/react",
			"@chancedigital/eslint-config/typescript"
		],
		"rules": {
			"require-await": 0
		}
	},
	"eslintIgnore": [
		"public/**/*"
	],
	"postcss": {
		"plugins": [
			"postcss-flexbugs-fixes",
			[
				"postcss-preset-env",
				{
					"autoprefixer": {
						"flexbox": "no-2009"
					},
					"stage": 1,
					"features": {
						"custom-media-queries": true,
						"custom-properties": false
					}
				}
			]
		]
	}
}
